# ============================================================================
#  Fnoon — environment variables to set in Coolify (the Compose file reads them).
#  Required ones have NO default; the rest fall back to sensible values.
# ============================================================================

# --- Required ---------------------------------------------------------------
# Generate once locally:  php artisan key:generate --show
APP_KEY=base64:CHANGE_ME
APP_URL=https://your-domain.com

DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-strong-root

# --- Optional (have defaults) ----------------------------------------------
APP_NAME=Fnoon
APP_LOCALE=ar
LOG_LEVEL=warning

DB_DATABASE=fnoon
DB_USERNAME=fnoon

FILESYSTEM_DISK=local

# Upload engine
UPLOAD_MAX_BYTES=32212254720   # 30 GB
UPLOAD_PART_SIZE=16777216      # 16 MB
UPLOAD_URL_TTL=60
MEDIA_MAX_KB=51200             # 50 MB

# ----------------------------------------------------------------------------
#  Storage (Cloudflare R2 / iDrive e2 / AWS S3) and Mail (SMTP) are configured
#  from the admin panel ( /admin -> Settings -> Storage / Email ) and stored in
#  the database, so they DON'T need to be set here.
# ----------------------------------------------------------------------------
