.idea
.vscode
.fleet

# Secrets & local env (provided by Coolify at runtime)
.env
.env.*
!.env.docker.example

# Dependencies (installed inside the image)
/vendor
/node_modules

# Build/runtime artefacts (regenerated in the container)
/public/build
/public/hot
/public/storage
/storage/app/public/*
/storage/app/uploads
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*

# Docker / CI bits not needed in the image
docker-compose*.yml
Dockerfile
.dockerignore
DEPLOY-COOLIFY.md

# Misc
/tests
phpunit.xml
README.md
*.sqlite
